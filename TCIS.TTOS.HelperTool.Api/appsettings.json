{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DeploySettings": {
    "Jobs": [
      {
        "Name": "webapp",
        "ComposeFile": "docker-compose.yml",
        "WorkingDirectory": "/app/deploy/webapp"

      },
      {
        "Name": "api-service",
        "ComposeFile": "docker-compose.yml",
        "WorkingDirectory": "/app/deploy/api"
      }
    ]
  },
  "Spx": {
    "BaseUrl": "https://spx.vn/"
  }
}
